{
  "node_id": "ezlight_001",
  "node_type": "ezlight",
  "profile": "experimental.ezlight.v1",
  "transport": "wifi_primary",
  "timezone": "Pacific/Auckland",
  "time_source": "ntp",
  "rtc_required": false,
  "astro_convention": "civil_dusk_civil_dawn",
  "relays": [
    { "id": "path_lights", "gpio": 14, "active_low": true, "mode": "manual" },
    { "id": "driveway_lights", "gpio": 27, "active_low": true, "mode": "manual" },
    { "id": "entrance_lights", "gpio": 26, "active_low": true, "mode": "schedule" },
    { "id": "spare_lights", "gpio": 25, "active_low": true, "mode": "disabled" }
  ],
  "schedule": { "enabled": false, "storage": "littlefs_json", "events": [], "rules": [] },
  "astro": {
    "location_set": true,
    "latitude": -42.45,
    "longitude": 171.21,
    "rules": [
      { "relay_id": "entrance_lights", "on": "civil_dusk", "off": "civil_dawn" }
    ]
  }
}
